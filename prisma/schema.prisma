// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Data model documented in CLAUDE.md section 4. Multi-tenant auth documented
// in CLAUDE.md section 9.

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  passwordHash String
  name         String?
  status       UserStatus @default(PENDING)
  isAdmin      Boolean    @default(false)
  approvedAt   DateTime?
  approvedById Int?
  approvedBy   User?      @relation("UserApprovals", fields: [approvedById], references: [id])
  approvedUsers User[]    @relation("UserApprovals")
  approvedBusinesses Business[] @relation("BusinessApprovals")
  createdAt    DateTime   @default(now())
  memberships  Membership[]
  sessions     Session[]
}

model Business {
  id           Int            @id @default(autoincrement())
  name         String
  status       BusinessStatus @default(PENDING)
  approvedAt   DateTime?
  approvedById Int?
  approvedBy   User?          @relation("BusinessApprovals", fields: [approvedById], references: [id])
  createdAt    DateTime       @default(now())
  memberships  Membership[]

  categories       Category[]
  products         Product[]
  attributes       Attribute[]
  attributeValues  AttributeValue[]
  variants         Variant[]
  variantAttributes VariantAttribute[]
  sales            Sale[]
  saleItems        SaleItem[]
  priceHistory     PriceHistory[]
  stockAdjustments StockAdjustment[]
  settings         Setting[]
}

model Membership {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  businessId Int
  business   Business @relation(fields: [businessId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Category {
  id         Int       @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  name       String
  active     Boolean   @default(true)
  products   Product[]
}

model Product {
  id         Int       @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  categoryId Int
  category   Category  @relation(fields: [categoryId], references: [id])
  name       String
  active     Boolean   @default(true)
  notes      String?
  variants   Variant[]
}

model Attribute {
  id         Int              @id @default(autoincrement())
  businessId Int
  business   Business         @relation(fields: [businessId], references: [id])
  name       String
  unit       String?
  values     AttributeValue[]
}

model AttributeValue {
  id           Int                @id @default(autoincrement())
  businessId   Int
  business     Business           @relation(fields: [businessId], references: [id])
  attributeId  Int
  attribute    Attribute          @relation(fields: [attributeId], references: [id])
  value        String
  sortOrder    Int                @default(0)
  variantLinks VariantAttribute[]
}

model Variant {
  id           Int                @id @default(autoincrement())
  businessId   Int
  business     Business           @relation(fields: [businessId], references: [id])
  productId    Int
  product      Product            @relation(fields: [productId], references: [id])
  sku          String?
  price        Int
  cost         Int?
  stockQty     Int                @default(0)
  reorderLevel Int?
  active       Boolean            @default(true)
  attributes   VariantAttribute[]
  saleItems    SaleItem[]
  priceHistory PriceHistory[]
  adjustments  StockAdjustment[]
}

model VariantAttribute {
  businessId       Int
  business         Business       @relation(fields: [businessId], references: [id])
  variantId        Int
  variant          Variant        @relation(fields: [variantId], references: [id])
  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeValueId])
}

model Sale {
  id          Int        @id @default(autoincrement())
  businessId  Int
  business    Business   @relation(fields: [businessId], references: [id])
  soldAt      DateTime   @default(now())
  customer    String?
  totalAmount Int
  note        String?
  items       SaleItem[]
}

model SaleItem {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  saleId     Int
  sale       Sale     @relation(fields: [saleId], references: [id])
  variantId  Int
  variant    Variant  @relation(fields: [variantId], references: [id])
  qty        Int
  unitPrice  Int
  unitCost   Int?
  lineTotal  Int
}

model PriceHistory {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  variantId  Int
  variant    Variant  @relation(fields: [variantId], references: [id])
  price      Int
  cost       Int?
  changedAt  DateTime @default(now())
  changedBy  String?
}

model StockAdjustment {
  id         Int      @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  variantId  Int
  variant    Variant  @relation(fields: [variantId], references: [id])
  delta      Int
  reason     String
  createdAt  DateTime @default(now())
  note       String?
}

model Setting {
  id         Int       @id @default(autoincrement())
  businessId Int
  business   Business  @relation(fields: [businessId], references: [id])
  key        String
  value      String

  @@unique([businessId, key])
}
